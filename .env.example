# ================================
# REQUIRED - Fill these values
# ================================

DISCORD_BOT_TOKEN=your_bot_token_here
BOT_OWNER_IDS=your_discord_user_id_here

# Discord OAuth (get from https://discord.com/developers/applications)
DISCORD_OAUTH_CLIENT_ID=1519806811744632994
DISCORD_OAUTH_CLIENT_SECRET=your_oauth_client_secret_here

# ================================
# WEB DASHBOARD
# ================================

WEB_DASHBOARD_ENABLED=true
WEB_DASHBOARD_HOST=0.0.0.0
WEB_DASHBOARD_PORT=8080

# Update this after Cloudflare Tunnel starts or with your domain
WEB_PUBLIC_URL=https://YOUR_TUNNEL_OR_DOMAIN

# OAuth Redirect (update with your domain/tunnel URL)
DISCORD_OAUTH_REDIRECT_URI=https://YOUR_TUNNEL_OR_DOMAIN/api/v1/auth/discord/callback
WEB_CORS_ORIGINS=https://YOUR_TUNNEL_OR_DOMAIN

# Security
WEB_COOKIE_SECURE=true
WEB_SESSION_SECRET=change_this_to_random_secret_use_openssl_rand_hex_32

# ================================
# INTERNAL (Auto-generated)
# ================================

# Generate with: openssl rand -hex 32
WOS_API_KEY=your_internal_wos_key_here

UPDATE_CHANNEL=stable
UPDATE_CHECK_URL=
AUTO_APPLY_UPDATES=false
UPDATES_ENABLED=true
UPDATE_AUTO_PATCH=true
UPDATE_AUTO_MINOR=false
UPDATE_AUTO_MAJOR=false

BACKUP_DIR=backups
LOGS_DIR=logs
DB_DIR=db
MAX_BACKUPS=10
MAX_LOG_SIZE_MB=10
MAX_LOG_FILES=10

MONITOR_INTERVAL=60
WATCHDOG_INTERVAL=60
PREDICTION_INTERVAL=300
DIAGNOSTICS_INTERVAL=21600
BACKUP_INTERVAL=86400
LOG_ROTATION_INTERVAL=1800
CLEANUP_INTERVAL=21600
UPDATE_CHECK_INTERVAL=43200

MEMORY_WARNING_THRESHOLD=80
DISK_WARNING_THRESHOLD=85

LOG_LEVEL=INFO

SECURITY_ENABLED=true
SECURITY_SCAN_ON_STARTUP=true
AUDIT_LOGS_ENABLED=true
ABUSE_GUARD_ENABLED=true
MAX_INVALID_INPUTS_PER_WINDOW=5
ABUSE_WINDOW_SECONDS=120
TEMP_BLOCK_SECONDS=600
ADMIN_DENIED_ALERT_THRESHOLD=3
SECRET_SCAN_ENABLED=true

CONFIRM_CLEAR_COMMANDS=false

BOT_OWNER_IDS=

ALLIANCE_API_ENABLED=false
ALLIANCE_API_PROVIDER=manual
ALLIANCE_API_BASE_URL=
ALLIANCE_API_KEY=
ALLIANCE_API_TIMEOUT_SECONDS=15
ALLIANCE_API_SYNC_INTERVAL_MINUTES=60
ALLIANCE_API_AUTO_SYNC=false
ALLIANCE_API_MAX_RETRIES=3
ALLIANCE_API_RATE_LIMIT_PER_MINUTE=30
